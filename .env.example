# LLM Provider Configuration
# Configure at least one provider for QA generation

# Using Google Gemini configuration
GOOGLE_API_KEY=your_api_key_here

# Using OpenAI configuration
OPENAI_API_KEY=your_openai_key_here

# GraphQL Polling Service Configuration
# OAuth 2.0 Client Credentials for GraphQL API access
GRAPHQL_CLIENT_ID=your_client_id_here
GRAPHQL_CLIENT_SECRET=your_client_secret_here
GRAPHQL_TOKEN_URL=https://auth.example.com/oauth/token

# Apollo GraphQL headers
APOLLOGRAPHQL_CLIENT_NAME=docta-poller

# Optional: Custom CA certificate for SSL
# GRAPHQL_CERT_PATH=/etc/ssl/certs/custom-ca-bundle.crt
